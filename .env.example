# Book Management API — Environment Variables
# Copy file này thành .env và điền giá trị thật
# cp .env.example .env

# ── App ──────────────────────────────────────────────────────────────────────
PROJECT_NAME=Book Management API
ENV=development
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./app.db

# ── OpenAI — credentials ─────────────────────────────────────────────────────
OPENAI_API_KEY=             # sk-proj-... lấy từ platform.openai.com/api-keys
OPENAI_BASE_URL=https://api.openai.com/v1   # đổi nếu dùng proxy hoặc local LLM

# ── OpenAI — models ──────────────────────────────────────────────────────────
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── OpenAI — timeouts ────────────────────────────────────────────────────────
OPENAI_CHAT_TIMEOUT=30.0
OPENAI_EMBEDDING_TIMEOUT=10.0

# ── OpenAI — token limits per task ───────────────────────────────────────────
OPENAI_MAX_TOKENS_SUMMARIZE=200
OPENAI_MAX_TOKENS_DESCRIBE=250
OPENAI_MAX_TOKENS_ANALYZE=150
OPENAI_MAX_TOKENS_DEFAULT=300

# ── OpenAI — temperatures ─────────────────────────────────────────────────────
OPENAI_TEMPERATURE_DEFAULT=0.7
OPENAI_TEMPERATURE_CREATIVE=0.8
OPENAI_TEMPERATURE_JSON=0.2
OPENAI_TEMPERATURE_SCHEMA=0.0

# ── AI behaviour ─────────────────────────────────────────────────────────────
AI_EMBED_RATE_LIMIT_SLEEP=0.1     # sleep giây giữa batch embedding calls
AI_SEMANTIC_SEARCH_THRESHOLD=0.3  # cosine similarity tối thiểu (0.0 - 1.0)

# ── RAG — bài 143-153 ─────────────────────────────────────────────────────────
RAG_UPLOAD_DIR=uploads            # thư mục lưu PDF upload tạm
RAG_CHROMA_DIR=.chroma            # ChromaDB persistent directory (tạo tự động)

# Chunking (bài 151)
RAG_CHUNK_SIZE=1000               # max ký tự mỗi chunk
RAG_CHUNK_OVERLAP=200             # overlap giữa 2 chunks liền kề (giữ context)

# Retrieval (bài 152)
RAG_RETRIEVAL_TOP_K=4             # số chunks trả về khi similarity search

# Token limits cho RAG (nhiều hơn title-based vì phải xử lý context dài hơn)
RAG_MAX_TOKENS_SUMMARIZE=600
RAG_MAX_TOKENS_QA=500
